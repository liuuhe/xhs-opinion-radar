{
  "name": "public-opinion-local",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:local": "vite build --config vite.local.config.ts",
    "local": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1",
    "local:webui": "npm run build:local && node scripts/local-webui.mjs",
    "local:bert": "powershell -ExecutionPolicy Bypass -File scripts/start-local-bert.ps1",
    "build": "tsc -b && npm run build:local",
    "preview": "npm run build:local && vite preview --config vite.local.config.ts --host 0.0.0.0",
    "mediacrawler:xhs": "powershell -ExecutionPolicy Bypass -File scripts/run-mediacrawler-xhs.ps1",
    "mediacrawler:to-capture": "node scripts/mediacrawler-to-capture.mjs",
    "dataset:from-captures": "node scripts/dataset-from-captures.mjs",
    "dataset:label-llm": "node scripts/dataset-label-llm.mjs",
    "dataset:merge": "node scripts/dataset-merge.mjs",
    "check": "tsc -b"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
