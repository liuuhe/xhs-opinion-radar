{
  "name": "public-opinion-cloudflare",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "npm run build && vite preview --host 0.0.0.0",
    "deploy": "npm run build && wrangler deploy",
    "check": "tsc -b",
    "test:worker": "vitest run --config vitest.config.ts",
    "cf:kv:create": "wrangler kv namespace create PUBLIC_OPINION_KV",
    "cf:upload-session": "wrangler kv key put xhs:storage_state --path sessions/xiaohongshu_storage_state.json --binding PUBLIC_OPINION_KV --remote"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/playwright": "^1.3.0",
    "@cloudflare/vite-plugin": "^1.18.8",
    "@cloudflare/workers-types": "^4.20260417.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.15",
    "wrangler": "^4.82.2"
  }
}
